# ================================================
# 백엔드 환경변수 예시 파일 (.env.example)
# ================================================
# ✅  이 파일은 GitHub에 올려도 됩니다 (실제 값이 없음)
# ✅  실제 .env 파일 만들 때 이 파일을 복사해서 값만 채우세요
#     cp .env.example .env
# ================================================

# --- 데이터베이스 ---
SPRING_DATASOURCE_URL=jdbc:mysql://호스트주소:3306/sprevn?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=DB계정명
SPRING_DATASOURCE_PASSWORD=DB비밀번호

# --- JWT 시크릿 키 (32자 이상 아무 문자열) ---
JWT_SECRET=여기에_32자_이상의_시크릿키_입력

# --- 서버 포트 ---
SERVER_PORT=8080
